{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    /* ✅ ADD THESE TWO (REQUIRED FOR SHADCN) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    /* Existing config (kept safe) */
    "module": "nodenext",
    "target": "esnext",
    "types": [],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src"]
}
